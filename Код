PROGRAM PLC_PRG
//Сначала все переменные (как коробка с деталями)
VAR
	//Входы (кнопки и датчики)
	StartButton AT %IX0.0 : BOOL; //Кнопка "ПУСК" (нажал = TRUE). Привязываем переменную к физ.порту с помощью AT.
	StopButton AT %IX0.1 : BOOL; //Кнопка "СТОП" (нажал = TRUE)
	LimitSwitch AT %IX0.2 : BOOL; //Механический датчик (концевик) сработал = TRUE
	
	//Выходы (что управляем)
	Motor AT %QX0.0 : BOOL; //Двигатель конвейера (TRUE = работает)
	
	//Переменные для логики
	Start_true : BOOL; //запомнили, что ПУСК нажали
	TimerRunning : BOOL; //Таймер сейчас тикает?
	TimerEnd : BOOL; //Таймер дотикал до конца?
	
	//Таймер
	MyTimer : TON; //Таймер с задержкой включения
    TimerMs : DINT; //время в мс.
    TimerSec : REAL; //время в с.
	
	//Для самодельного детектора фронта
	StartLastState : BOOL; //Предыдущее состояние кнопки ПУСК
END_VAR

// !!! УДАЛИТЕ НЕИСПОЛЬЗУЕМЫЕ ИНТЕРФЕЙСЫ (RS-485, RS-232, Ethernet) ИЗ ПРОЕКТА !!!
//Часть 1: Детектор нажатия кнопки "Пуск" (ловим момент, когда кнопку только нажали, а не просто держат)

IF StartButton = TRUE AND StartLastState = FALSE THEN
	//Если сейчас нажата, а в прошлый раз была не нажата
	//значит ее только что нажали
	Start_true := TRUE; //запоминаем, что был запуск
END_IF

StartLastState := StartButton; //Запоминаем тек.состояние для след.цикла

//Часть 2: Условия для запуска таймера
//Таймер должен работать, если: 
//1.Нажали пуск - 2.Не нажат стоп - 3.не сработал концевик

IF Start_true = TRUE AND StopButton = FALSE AND LimitSwitch = FALSE THEN
	TimerRunning := TRUE; //Разрешаем таймеру работать
ELSE
	TimerRunning := FALSE; //Иначе останавливаем таймер
END_IF

//Часть 3: Работа таймера на 2 сек
//TON работает так:
//IN = TRUE(начинает тикать), FALSE(сбрасывается в 0), Q = TRUE (когда протикало PT сек)

//это копия функционального блока TON, используем каждый его цикл
MyTimer(
	IN := TimerRunning,  //Вкл таймер, если TimerRunning = TRUE; Вход: разрешение работать
	PT := T#2S //время 2 сек; Вход: время задержки
);
(*у блока появляются выходы:
MyTimer.Q - TRUE когда время вышло
MyTimer.ET - сколько времени прошло(в милллисекундах)
Блок помнит счетчик между циклами*)
TimerEnd := MyTimer.Q; //сохраняем флаг "таймер дотикал"
TimerMs := TIME_TO_DINT(MyTimer.ET); (*MyTimer.ET - сколько времени прошло в мс. 
Преобразуем тип TIME в число DINT и рез-т сохраняем в TimerMs.*)
TimerSec := TimerMs / 1000.0; //Делим мс. на 1000 и получаем сек. с запятой.

//Часть 4: вкл двигателя
(*Двигатель работает, когда:
1)таймер дотикал до конца(TimerEnd = TRUE
2)стоп не нажат
3)концевик не сработал *)
IF TimerEnd = TRUE AND StopButton = FALSE AND LimitSwitch = FALSE THEN
	Motor := TRUE; //Вкл мотор
END_IF

IF StopButton = TRUE OR LimitSwitch = TRUE THEN
	Motor := FALSE; //Выкл мотор
END_IF

//Часть 5: сброс флага "пуск нажат" при остановке
//Чтобы запустить конвейер снова, нужно снова нажать пуск

IF StopButton = TRUE OR LimitSwitch = TRUE THEN
	Start_true := FALSE; //Забываем, что пуск нажимали
END_IF
//если мотор отработал 2 сек и выключился, тоже сбрасываем
IF TimerEND = TRUE THEN
	Start_true := FALSE;
END_IF
